APP_NAME=Kondo API

# SQLite (desenvolvimento local sem Docker)
DATABASE_URL=sqlite:///./kondo.db

# PostgreSQL (Docker ou banco externo) — descomente e ajuste para usar
# DATABASE_URL=postgresql://kondo:kondo@localhost:5432/kondo

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
OPENAI_API_KEY=
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=
AI_ENABLE_MOCK_FALLBACK=true
AI_TIMEOUT_SECONDS=12
JWT_SECRET_KEY=dev-only-change-me

